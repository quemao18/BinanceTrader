# Binance API credentials
API_KEY=your_api_key_here
SECRET=your_secret_here

# Bot configuration
# Spot pair to trade (e.g., BTCUSDT, ETHUSDT)
TRADING_PAIR=BTCUSDT
# Candle timeframe used for features and execution cadence
TIMEFRAME=15m
# Use Binance testnet credentials when true
TESTNET=false
# Trading venue mode: spot or futures
TRADE_MODE=spot
# Avoid private currency-metadata call (helps in some cloud regions)
SKIP_FETCH_CURRENCIES=true
# Run one bounded execution and exit (recommended for Cloud Run Jobs)
SINGLE_RUN=true
# Max cycles executed per container run when SINGLE_RUN=true
MAX_CYCLES_PER_RUN=1
# Sleep between cycles in the same run
SLEEP_BETWEEN_CYCLES_SEC=30
# Skip cycle if no new closed candle is available
ONLY_NEW_CANDLE=true
# Max fraction of quote balance used on a new spot entry (0.25 = 25%)
MAX_POSITION_PCT=0.25
# Probability threshold to open/keep long
BUY_THRESHOLD=0.60
# Probability threshold to close to flat
SELL_THRESHOLD=0.40
# Load BUY/SELL thresholds from best_thresholds.json when available
AUTO_LOAD_BEST_THRESHOLDS=true
# Path to calibrated thresholds generated by Preprocessing.py
BEST_THRESHOLDS_PATH=best_thresholds.json
# Local file to persist bot runtime state between runs
STATE_FILE=bot_state.json
# If this file exists, bot skips trading cycle (manual kill switch)
KILL_SWITCH_FILE=.pause_trading

# Training configuration (Preprocessing.py)
# Baseline forward-return threshold for positive class label
FORWARD_RETURN_THRESHOLD=0.0
# Prediction horizon in candles for target creation
TARGET_HORIZON_CANDLES=3
# Extra label strictness vs estimated trading costs
TARGET_COST_MULTIPLIER=2.0
# Rolling window to smooth model probabilities before signaling
PROBA_SMOOTH_WINDOW=3
# Minimum candles to hold a position before allowing exit
MIN_HOLD_CANDLES=4
# Minimum gap between buy and sell thresholds (hysteresis)
MIN_THRESHOLD_GAP=0.05
# Default volatility quantile cap for regime filter
REGIME_MAX_VOL_QUANTILE=0.80
# Candidate volatility quantiles explored during calibration
REGIME_QUANTILE_GRID=0.70,0.80,0.90
# Per-side estimated exchange fee used in backtest
BACKTEST_FEE_RATE=0.001
# Per-side estimated slippage used in backtest
BACKTEST_SLIPPAGE_RATE=0.0005
# Minimum number of trades required to accept calibrated thresholds
MIN_TRADES_CALIBRATION=50
# GO/NO_GO: minimum test return required
GO_MIN_TEST_RETURN=0.0
# GO/NO_GO: worst allowed drawdown floor
GO_MAX_DRAWDOWN=-0.15
# GO/NO_GO: minimum Sharpe ratio
GO_MIN_SHARPE=0.25
# GO/NO_GO: minimum win rate
GO_MIN_WIN_RATE=0.50
# GO/NO_GO: minimum number of test trades
GO_MIN_TRADE_EVENTS=100
# GO/NO_GO: strategy return must beat buy-and-hold by at least this alpha
GO_MIN_ALPHA_VS_BH=0.0

# Runtime safety gate
# Block startup unless latest training_metrics.json status is GO
REQUIRE_GO_NO_GO=false
# Path to training report consumed by GO/NO_GO gate
TRAINING_METRICS_PATH=training_metrics.json